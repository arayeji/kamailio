# IMS NMS HTTP API settings (P-CSCF)
# Copy to nms-api.cfg next to P-CSCF kamailio.cfg

listen=tcp:127.0.0.1:9281

tcp_accept_no_cl=yes

modparam("ims_nms_api", "api_token", "CHANGE_ME")
modparam("ims_nms_api", "api_host", "cscf-example")
modparam("ims_nms_api", "api_listen_ip", "127.0.0.1")
modparam("ims_nms_api", "api_listen_port", 9281)
modparam("ims_nms_api", "cscf_role", "pcscf")
modparam("ims_nms_api", "plmn_realm", "ims.mnc001.mcc001.3gppnetwork.org")
